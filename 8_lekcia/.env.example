# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# OpenAI API Key
OPENAI_API_KEY="strong_api_key_here"

# Azure SQL Server credentials
AZURE_SQL_SERVER="database_name.database.windows.net"
AZURE_SQL_DATABASE="database_name"
AZURE_SQL_USERNAME="AppUser"    
AZURE_SQL_PASSWORD='my_secure_password'
